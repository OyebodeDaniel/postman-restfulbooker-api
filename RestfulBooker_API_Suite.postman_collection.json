      "item": [
        {
          "name": "Ping — API is alive",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health check returns 201', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response body is Created', () => {",
                  "  pm.expect(pm.response.text()).to.include('Created');",
                  "});",
