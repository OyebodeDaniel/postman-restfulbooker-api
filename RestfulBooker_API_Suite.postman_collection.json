              "raw": "{\n  \"firstname\": \"Daniel\",\n  \"lastname\": \"Updated\",\n  \"totalprice\": 350,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2025-06-01\",\n    \"checkout\": \"2025-06-07\"\n  },\n  \"additionalneeds\": \"Lunch\"\n}"
