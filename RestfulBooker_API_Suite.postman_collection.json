    {
      "name": "Booking — Update",
      "item": [
        {
          "name": "Update Booking — full update (PUT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Update Booking — full update : Updated fields reflect new values', () => {",
                  "    const booking = pm.response.json();",
                  "    pm.expect(booking.firstname).to.eql('Daniel');",
                  "    pm.expect(booking.lastname).to.eql('Updated');",
                  "    pm.expect(booking.totalprice).to.eql(350);",
                  "    pm.expect(booking.depositpaid).to.eql(false);",
                  "});",
                  "",
                  "pm.test('Update Booking — full update : Booking dates are updated', () => {",
                  "    pm.expect(pm.response.json().bookingdates.checkin).to.eql('2025-06-01');",
                  "    pm.expect(pm.response.json().bookingdates.checkout).to.eql('2025-06-07');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
