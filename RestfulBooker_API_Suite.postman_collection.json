    {
      "name": "Booking — Create",
      "item": [
        {
          "name": "Create Booking — Valid payload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save new booking ID for update and delete tests",
                  "pm.environment.set(\"newId\", pm.response.json().bookingid);",
                  "",
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Create Booking — Valid payload : Response contains bookingid', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('bookingid');",
                  "});",
                  "",
                  "pm.test('Create Booking — Valid payload : Response contains booking object', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('booking');",
                  "});",
                  "",
                  "pm.test('Create Booking — Valid payload : Created booking matches request payload', () => {",
                  "  const booking = pm.response.json().booking;",
                  "  pm.expect(booking.firstname).to.eql('John');",
                  "  pm.expect(booking.lastname).to.eql('Doe');",
                  "  pm.expect(booking.totalprice).to.eql(250);",
                  "  pm.expect(booking.depositpaid).to.eql(true);",
                  "  pm.expect(booking.bookingdates.checkin).to.eql('2025-01-15');",
                  "  pm.expect(booking.bookingdates.checkout).to.eql('2025-01-20');",
                  "});",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"John\",\n  \"lastname\": \"Doe\",\n  \"totalprice\": 250,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2025-01-15\",\n    \"checkout\": \"2025-01-20\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking"
              ]
            }
