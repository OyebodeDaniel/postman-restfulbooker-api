    {
      "name": "Auth",
      "item": [
        {
          "name": "Create Token — Valid credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save token to environment for use in PUT, PATCH, DELETE",
                  "pm.environment.set(\"Token\", pm.response.json().token);",
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Create Token — Valid credentials : Auth Token is Returned\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.not.empty;",
                  "});",
                  "",
                  "",
                  ""
                ],
