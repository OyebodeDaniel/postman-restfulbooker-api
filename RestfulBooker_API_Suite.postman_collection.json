    {
      "name": "Booking — Read",
      "item": [
        {
          "name": "Get All Booking IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save first id for the Get by ID test",
                  "pm.environment.set(\"existingBookingId\", pm.response.json()[0].bookingid);",
                  "",
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Get All Booking IDs - Successful - Each entry has a bookingid field', () => {",
                  "  pm.response.json().forEach(item => {",
                  "    pm.expect(item).to.have.property('bookingid');",
                  "    pm.expect(item.bookingid).to.be.a('number');",
                  "  });",
                  "});",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Booking by ID — Valid ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Get Booking by ID — Valid ID : Response contains required booking fields', () => {",
                  "  const booking = pm.response.json();",
                  "  pm.expect(booking).to.have.property('firstname');",
                  "  pm.expect(booking).to.have.property('lastname');",
                  "  pm.expect(booking).to.have.property('totalprice');",
                  "  pm.expect(booking).to.have.property('depositpaid');",
                  "  pm.expect(booking).to.have.property('bookingdates');",
                  "  pm.expect(booking.bookingdates).to.have.property('checkin');",
                  "  pm.expect(booking.bookingdates).to.have.property('checkout');",
                  "});",
                  "",
                  "pm.test('Get Booking by ID — Valid ID : totalprice is a number', () => {",
                  "  pm.expect(pm.response.json().totalprice).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Get Booking by ID — Valid ID: depositpaid is a boolean', () => {",
                  "  pm.expect(pm.response.json().depositpaid).to.be.a('boolean');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/booking/{{existingBookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking",
                "{{existingBookingId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Booking by ID — non-existent ID",
          "event": [
            {
